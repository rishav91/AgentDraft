# Copy to .env and fill in what your schema needs. Agentic Graph Composer loads .env from the current
# directory automatically - a real exported env var always wins over this file.

# Provider API keys - set whichever your schema's `llm.provider` fields use.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Postgres-backed checkpointing (only if a schema's `checkpointer.backend` is `postgres`).
# The variable name must match that schema's `checkpointer.dsn_env` field exactly - this is
# an illustrative name below, not a fixed one Agentic Graph Composer looks for.
# POSTGRES_DSN=postgresql://user:password@host:5432/dbname

# Observability (optional) - if unset, spans are created but exported nowhere.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=agc
